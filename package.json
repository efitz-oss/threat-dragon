{
  "name": "threat-dragon",
  "version": "2.4.1",
  "appBundleId": "org.owasp.threatdragon",
  "private": true,
  "type": "module",
  "workspaces": [
    "td.server",
    "td.vue"
  ],
  "scripts": {
    "audit": "npm-run-all -c audit:server audit:site",
    "audit:server": "npm run audit --workspace=td.server",
    "audit:site": "npm run audit --workspace=td.vue",
    "build": "npm-run-all build:vue build:server",
    "build:desktop": "npm run build:desktop --workspace=td.vue",
    "build:server": "npm run build --workspace=td.server",
    "build:vue": "npm run build --workspace=td.vue",
    "clean": "npm-run-all clean:server clean:vue clean:root",
    "clean:server": "npm run clean --workspace=td.server",
    "clean:root": "rimraf node_modules/",
    "clean:vue": "npm run clean --workspace=td.vue",
    "dev:vue": "cd td.vue && NODE_OPTIONS='--no-warnings' ../node_modules/.bin/vite",
    "dev:server": "node td.server/dev.mjs",
    "format": "npm-run-all format:server format:vue",
    "format:server": "npm run format --workspace=td.server",
    "format:vue": "npm run format --workspace=td.vue",
    "format:check": "npm-run-all format:check:server format:check:vue",
    "format:check:server": "npm run format:check --workspace=td.server",
    "format:check:vue": "npm run format:check --workspace=td.vue",
    "lint": "npm-run-all lint:server lint:vue",
    "lint:server": "npm run lint --workspace=td.server",
    "lint:vue": "npm run lint --workspace=td.vue",
    "lint:check": "npm-run-all lint:check:server lint:check:vue",
    "lint:check:server": "npm run lint:check --workspace=td.server",
    "lint:check:vue": "npm run lint:check --workspace=td.vue",
    "pretest": "npm-run-all pretest:server pretest:site",
    "pretest:server": "npm run pretest --workspace=td.server",
    "pretest:site": "npm run pretest --workspace=td.vue",
    "start": "npm-run-all build:vue build:server start:server start:site",
    "start:desktop": "cd td.vue && NODE_OPTIONS='--no-warnings' ../node_modules/.bin/vite --mode electron && electron .",
    "start:server": "npm run start:server --workspace=td.server",
    "start:site": "npm run start:serve --workspace=td.vue",
    "stop": "npm-run-all stop:site stop:server",
    "stop:server": "npm run stop:server --workspace=td.server",
    "stop:site": "npm run stop:serve --workspace=td.vue",
    "test": "npm-run-all build pretest test:site test:server test:desktop",
    "test:desktop": "npm run test:desktop --workspace=td.vue",
    "test:e2e:desktop": "npm run build:desktop --workspace=td.vue -- --publish=never && npm run test:e2e:desktop --workspace=td.vue",
    "test:server": "NODE_OPTIONS=--experimental-vm-modules npm run test:unit --workspace=td.server",
    "test:site": "npm run test:unit --workspace=td.vue",
    "test:vue": "npm run test:vue --workspace=td.vue",
    "test:fast": "npm run test:fast --workspace=td.vue",
    "test:fast:watch": "npm run test:fast:watch --workspace=td.vue",
    "test:fast:coverage": "npm run test:fast:coverage --workspace=td.vue",
    "test:fast:ui": "npm run test:fast:ui --workspace=td.vue"
  },
  "keywords": [
    "threat dragon",
    "OWASP",
    "threat modeling",
    "STRIDE",
    "LINDDUN",
    "CIA",
    "DIE",
    "PLOT4ai"
  ],
  "description": "OWASP Threat Dragon - a free, open source threat modeling tool",
  "author": {
    "name": "OWASP Threat Dragon",
    "email": "jon.gadsden@owasp.org",
    "url": "https://owasp.org/www-project-threat-dragon/"
  },
  "license": "Apache-2.0",
  "homepage": "https://owasp.org/www-project-threat-dragon/",
  "repository": {
    "type": "git",
    "url": "git://github.com/OWASP/threat-dragon.git"
  },
  "bugs": {
    "email": "jon.gadsden@owasp.org",
    "url": "https://github.com/OWASP/threat-dragon/issues"
  },
  "dependencies": {
    "axios": "^1.8.2",
    "dotenv": "^16.4.7",
    "pm2": "^5.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.21.4",
    "@babel/register": "^7.23.7",
    "@npmcli/fs": "^3.1.1",
    "@wdio/cli": "^8.38.2",
    "eslint": "^8.46.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "rimraf": "^4.4.1"
  },
  "overrides": {
    "@babel/traverse": ">=7.23.2",
    "@npmcli/move-file": "npm:@npmcli/fs@^3.0.0",
    "@pm2/agent": ">=2.0.4",
    "ansi-regex": "5.0.1",
    "ansi-regex@>2.1.1 <5.0.1": ">=5.0.1",
    "app-builder-lib": ">=24.13.2",
    "electron-notarize": "npm:@electron/notarize@^2.5.0",
    "electron-osx-sign": "npm:@electron/osx-sign@^1.3.3",
    "@cyclonedx/cyclonedx-library": ">=3.0.0",
    "@cyclonedx/cyclonedx-npm": ">=1.10.0",
    "@cyclonedx/webpack-plugin": ">=4.0.0",
    "libxmljs2": "npm:@npmcli/fs@^3.0.0",
    "body-parser": ">=1.20.3",
    "braces": ">=3.0.3",
    "cookie": ">=0.7.0",
    "cross-spawn@<7.0.0": "6.0.6",
    "cross-spawn@>=7.0.0": ">=7.0.5",
    "debug@<3.1.0": ">=4.3.4",
    "follow-redirects": ">=1.15.6",
    "glob-parent@<5.1.2": ">=5.1.2",
    "got": ">=11.8.5",
    "ip@<1.1.9": "1.1.9",
    "ip@=2.0.0": ">=2.0.1",
    "micromatch": ">=4.0.8",
    "minimatch@<3.0.5": ">=3.0.5",
    "path-to-regexp@<1.0.0": "0.1.12",
    "postcss@<8.4.31": ">=8.4.31",
    "request": "npm:axios@^1.8.1",
    "progress-webpack-plugin": {
      "ansi-regex": "5.0.1",
      "strip-ansi": "6.0.1",
      "string-width": "4.2.3"
    },
    "send": ">=0.19.0",
    "semver": ">=7.5.4",
    "serialize-javascript": ">=6.0.2",
    "simple-update-notifier": ">=2.0.0",
    "strip-ansi": "6.0.1",
    "string-width": "4.2.3",
    "systeminformation": ">=5.23.23",
    "tar": ">=6.2.1",
    "tough-cookie@<4.1.3": ">=4.1.3",
    "vm2@<3.9.16": ">=3.9.19",
    "ws": ">=8.18.0"
  }
}
