{
  "name": "threat-dragon",
  "productName": "Threat Dragon",
  "version": "2.4.1",
  "appBundleId": "org.owasp.threatdragon",
  "private": true,
  "type": "module",
  "scripts": {
    "audit": "npm audit",
    "build": "../node_modules/.bin/vite build --emptyOutDir",
    "build:minimal": "NODE_ENV=production ../node_modules/.bin/vite build --emptyOutDir --config vite.minimal.config.js",
    "build:analyze": "ANALYZE=true ../node_modules/.bin/vite build",
    "build:desktop": "../node_modules/.bin/vite build --mode electron && electron-builder",
    "make-sbom": "cyclonedx-node -o .sbom/sbom-frontend.json",
    "clean": "rimraf coverage/ cypress/ dist/ dist-desktop/ node_modules/ tests/e2e/videos/ tests/e2e/reports/ tests/e2e/screenshots/ log/ results/",
    "cypress:open": "cypress open",
    "cypress:update": "npx update-browserslist-db@latest",
    "dev": "NODE_OPTIONS='--no-warnings' ../node_modules/.bin/vite",
    "fix-deps": "node ./fix-dependencies.js",
    "scan-migration": "node ./scan-for-migration.js",
    "format": "prettier --write 'src/**/*.{js,vue,jsx,mjs}' 'tests/**/*.{js,vue}'",
    "format:check": "prettier --check 'src/**/*.{js,vue,jsx,mjs}' 'tests/**/*.{js,vue}'",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "lint:check": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --ignore-path .gitignore",
    "lint:desktop": "eslint src/desktop tests/unit/desktop --ext .js --fix",
    "pretest": "npm run lint && npm run lint:desktop",
    "serve": "NODE_OPTIONS='--no-warnings' ../node_modules/.bin/vite",
    "start": "echo 'Please run the start command from the root of this repository' && exit 1",
    "start:desktop": "../node_modules/.bin/vite --mode electron && electron .",
    "start:serve": "pm2 --name td.vue start './vite-runner.mjs'",
    "stop:serve": "pm2 delete td.vue",
    "test": "npm run test:unit",
    "test:all": "vitest run",
    "test:desktop": "vitest run --config vitest.desktop.config.js",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:update-snapshots": "vitest run --update",
    "test:migrate-archive": "echo 'Migration is complete! See VUE3_TEST_MIGRATION_FINAL.md'",
    "test:fast": "vitest run --config vitest.fast.config.js",
    "test:fast:watch": "vitest --config vitest.fast.config.js --watch",
    "test:fast:coverage": "vitest run --config vitest.fast.config.js --coverage",
    "test:fast:ui": "vitest --config vitest.fast.config.js --ui",
    "test:e2e": "cypress run -C e2e.local.config.js",
    "test:e2e:desktop": "wdio run ./wdio.config.js",
    "test:e2e:local": "cypress run -C e2e.local.config.js --url http://localhost:8080/",
    "test:e2e-ci": "cypress run -C e2e.ci.config.js --browser chromium --headless --url http://localhost:3000/",
    "test:e2e-ci-smokes": "cypress run -C e2e.smokes.ci.config.js --browser chromium --headless --url http://localhost:3000/",
    "test:e2e-pr": "cypress run -C e2e.ci.config.js --browser chromium --headless --url http://localhost:8080/",
    "test:e2e-pr-smokes": "cypress run -C e2e.smokes.ci.config.js --browser chromium --headless --url http://localhost:8080/",
    "test:e2e-smokes": "browserstack-cypress run --cf browserstack.smokes.json --sync",
    "test:e2e-smokes:local": "cypress run -C e2e.smokes.local.config.js --url http://localhost:8080/",
    "test:e2e-nightly": "browserstack-cypress run --cf browserstack.nightly.json --sync",
    "test:unit": "vitest run --testPathIgnorePatterns tests/unit/desktop/",
    "test:vue": "cypress run -C e2e.local.config.js --headless --browser chrome",
    "test:migration-analysis": "node run-migration-analysis.js"
  },
  "description": "OWASP Threat Dragon - a free, open source threat modeling tool",
  "author": {
    "name": "OWASP Threat Dragon",
    "email": "jon.gadsden@owasp.org",
    "url": "https://owasp.org/www-project-threat-dragon/"
  },
  "license": "Apache-2.0",
  "homepage": "https://owasp.org/www-project-threat-dragon/",
  "buildState": "-latest",
  "repository": {
    "type": "git",
    "url": "git://github.com/OWASP/threat-dragon.git"
  },
  "bugs": {
    "email": "jon.gadsden@owasp.org",
    "url": "https://github.com/OWASP/threat-dragon/issues"
  },
  "dependencies": {
    "@antv/x6": "^2.18.1",
    "@antv/x6-plugin-clipboard": "^2.1.6",
    "@antv/x6-plugin-export": "^2.1.6",
    "@antv/x6-plugin-history": "^2.2.4",
    "@antv/x6-plugin-keyboard": "^2.2.3",
    "@antv/x6-plugin-scroller": "^2.0.10",
    "@antv/x6-plugin-selection": "^2.2.2",
    "@antv/x6-plugin-snapline": "^2.1.7",
    "@antv/x6-plugin-stencil": "^2.1.5",
    "@antv/x6-plugin-transform": "^2.1.8",
    "@antv/x6-vue-shape": "^2.1.2",
    "@fortawesome/fontawesome-svg-core": "^6.2.0",
    "@fortawesome/free-brands-svg-icons": "^6.2.0",
    "@fortawesome/free-solid-svg-icons": "^6.2.0",
    "@fortawesome/vue-fontawesome": "^3.0.8",
    "@intlify/core-base": "^9.14.3",
    "@intlify/shared": "^9.14.3",
    "@vue/devtools-api": "^7.7.2",
    "@vueuse/core": "^10.2.0",
    "ajv": "^8.11.0",
    "deep-pick-omit": "^1.2.1",
    "destr": "^2.0.3",
    "electron-log": "^5.3.2",
    "electron-updater": "^6.3.0",
    "fast-uri": "^3.0.6",
    "is-electron": "^2.2.1",
    "passive-events-support": "^1.1.0",
    "pinia": "^3.0.1",
    "pinia-plugin-persistedstate": "^4.2.0",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^3.53.1",
    "uuid": "^11.1.0",
    "vue": "^3.3.4",
    "vue-demi": "^0.14.10",
    "vue-i18n": "^9.14.3",
    "vue-router": "^4.2.2"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@pinia/testing": "^1.0.0",
    "@pm2/agent": ">=2.0.4",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/compiler-sfc": "^3.3.4",
    "@vue/test-utils": "^2.4.6",
    "browserstack-cypress-cli": "^1.31.9",
    "chromedriver": "^119.0.1",
    "cypress": "^13.7.3",
    "electron": "^26.3.0",
    "electron-builder": "^24.13.3",
    "electron-devtools-installer": "^3.2.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-cypress": "^2.14.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-n": "^15.2.4",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-vue": "^9.17.0",
    "jsdom": "^22.1.0",
    "patch-package": "^8.0.0",
    "postcss-selector-parser": "^6.1.2",
    "rollup-plugin-visualizer": "^5.9.2",
    "sass": "~1.64.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.8",
    "wdio-electron-service": "^3.5.1",
    "webdriverio": "^8.3.3"
  },
  "overrides": {
    "@achrinza/node-ipc": ">=10.1.11",
    "ejs@<3.1.10": ">=3.1.10",
    "elliptic": ">=6.6.1",
    "express": ">=4.20.0",
    "lodash@<4.17.21": ">=4.17.21",
    "minimist@>=1.0.0 <1.2.3": ">=1.2.3",
    "nanoid": "^3.3.8",
    "node-fetch": ">=2.6.7",
    "node-notifier@<8.0.1": ">=8.0.1",
    "node-ipc": ">=12.0.0",
    "nth-check@<2.0.1": ">=2.0.1",
    "path-to-regexp": ">=6.2.3",
    "requestretry": ">=7.0.0",
    "serialize-javascript": ">=6.0.3",
    "serve-static": ">=1.16.0",
    "tar@>=6.0.0 <6.1.9": ">=6.1.9",
    "electron-builder": "^24.13.3"
  },
  "main": "background.js",
  "resolutions": {
    "@npmcli/move-file": "npm:@npmcli/fs@^3.0.0",
    "electron-osx-sign": "npm:@electron/osx-sign@^1.3.3"
  }
}
